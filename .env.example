# Supabase — tiesverse.com landing site (public read-only)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard>

# Career site Node proxy (Cloudflare D1 — open positions)
# Set to wherever the Node proxy is hosted; leave unset to disable the positions section.
VITE_API_URL=http://localhost:5000

# Admin/Django backend — registration + Razorpay endpoints
VITE_ADMIN_API_URL=http://localhost:8000

# Career site URL — used for cross-site links
VITE_CAREER_URL=http://localhost:5173

# Razorpay — Key ID is public (safe to expose). Use test key for local dev.
VITE_RAZORPAY_KEY_ID=rzp_test_<your-test-key>
